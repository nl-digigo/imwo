imwos:IMWO a skos:ConceptScheme ;
    skos:prefLabel "IMWO"@nl ;
    dct:title "Informatiemodel Woongebouwen"@nl ;
    rdfs:label "IMWO"@nl .

imwom:Top a skos:Collection ;
    skos:prefLabel "Top"@nl ;
    skos:member imwo:Concept,
                imwo:AbstractConcept,
                imwo:AbstracteRuimte,
                imwo:TopologischeRuimte,
                imwo:GeometrischeRuimte,
                imwo:Tijd,
