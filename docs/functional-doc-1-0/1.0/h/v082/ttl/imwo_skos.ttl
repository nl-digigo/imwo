imwo:Concept a skos:Concept ;
    skos:inScheme imwos:IMWO ;
    skos:prefLabel "Concept"@nl ;
    skos:altLabel "concept"@nl ;
    skos:definition "enkelplaatsig enkelvoudig ding"@nl ;
    imwor:bronterm "TopConcept"@nl ;
    skos:scopeNote "Enkelplaatsig (unair) element dat existentieel onafhankelijk is."@nl ;
    skos:note "Enkelplaatsig: cardinaliteit=1: i.t.t. een 'relatie': die is meerplaatsig; enkelvoudig: atomair: kan (op een bepaald niveau) niet verder onderverdeeld worden."@nl ;
    skos:editorialNote "In NEN 2660:1 wordt dit 'Topconcept'genoemd, maar dat begrip wordt niet nader gedefinieerd.In NEN 2660-1 is een Concept verder een specialisatie van een element, 'een enkelvoudig ding dat lid kan zijn van een verzameling', met als extra eigenschap dat het 'existentieel onafhankelijk'is. Maar wat is 'existentieel onafhankelijk'?"@nl ;
    dct:source "[NEN 2660-1:2022]" ;
    imwor:bronBrondefinitie "[NEN 2660-1:2022]" ;
    dct:creator "digiGO"@nl ;
    imwor:eigenaarBrondefinitie "NEN"@nl ;
    imwor:schema "IMWO" ;
    imwor:model imwom:Top ;
    dct:identifier "7bf417f7-5234-11f1-a512-00ffdb61c323" ;
    skos:related imwo:Concept ;
    imwor:relatieCode "R3" ;
    imwor:relatieSoort "heeft relatie met"@nl ;
    imwor:relatieNaam "heeftRelatieMet"@nl ;
    imwor:parentPackage "NEN2660" ;
    imwor:gerelateerdAan imwo:Concept ;
    skos:broader imwo:Element ;
    imwor:relatieCode "R5" ;
    imwor:relatieSoort "is specialisatie van"@nl ;
    imwor:parentPackage "NEN2660" ;
    imwor:gerelateerdAan imwo:Element ;
    rdfs:isDefinedBy imwos:IMWO .

