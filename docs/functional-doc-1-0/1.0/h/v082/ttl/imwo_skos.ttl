    imwor:gerelateerdAan imwo:Activiteit ;
    skos:broader imwo:Functie ;
    imwor:relatieCode "R5" ;
    imwor:relatieSoort "is specialisatie van"@nl ;
    imwor:parentPackage "TopModel" ;
    imwor:gerelateerdAan imwo:Functie ;
    rdfs:isDefinedBy imwos:IMWO .

imwo:Toestand a skos:Concept ;
    skos:inScheme imwos:IMWO ;
    skos:prefLabel "Toestand"@nl ;
    skos:altLabel "toestand"@nl ;
    skos:definition "ConcreetConcept én Temporeel deel van een Entiteit"@nl ;
    imwor:bronterm "Toestand"@nl ;
    skos:scopeNote "Concreet Concept dat een temporeel deel van een entiteit (een object of activiteit) vormt gedurende een periode tussen twee gebeurtenissen. Een toestand is het geheel van omstandigheden of condities waarin een entiteit (object of activiteit) zich bevindt en wordt gekenmerkt door de relaties en eigenschappen (met hun waarde) van de entiteit gedurende deze periode."@nl ;
